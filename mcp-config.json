{
  "mcpServers": {
    "reasoning-traces": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "${CLAUDE_PLUGIN_ROOT}", "reasoning-traces"],
      "env": {
        "REASONING_BACKEND": "corethink",
        "CORETHINK_API_KEY": "${CORETHINK_API_KEY}"
      },
      "timeout": 600000
    }
  }
}
